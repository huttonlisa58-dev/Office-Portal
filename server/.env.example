# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ---- Database ----
MONGO_URI=mongodb://127.0.0.1:27017/hrms_saas

# ---- Auth ----
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

# ---- Default Super Admin (used by `npm run seed`) ----
SEED_ADMIN_EMAIL=admin@hrms.io
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Super Admin

# ---- Email (SMTP for OTP / notifications) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="HRMS SaaS <no-reply@hrms.io>"

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- WhatsApp (Meta Cloud API) — used by services/whatsapp.service.js ----
WHATSAPP_TOKEN=your_meta_token
WHATSAPP_PHONE_ID=your_phone_number_id

# ---- AI (optional, for HR assistant / anomaly explanations) ----
ANTHROPIC_API_KEY=
